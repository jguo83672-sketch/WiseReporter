# WiseReporter 环境配置示例

# Flask配置
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here

# 数据库配置 (可选)
# DATABASE_URL=sqlite:///wisereporter.db
# DATABASE_URL=postgresql://user:password@localhost/wisereporter
# DATABASE_URL=mysql://user:password@localhost/wisereporter

# 服务端口
PORT=5000

# 爬虫配置
REQUEST_TIMEOUT=30
RETRY_TIMES=3

# Cookie池配置
COOKIE_POOL_SIZE=5
COOKIE_EXPIRY_HOURS=24

